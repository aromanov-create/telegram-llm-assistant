BOT_TOKEN=replace-me
ALLOWED_USER_ID=123456789

# Имя пользователя — используется в system prompt и истории разговора.
USER_NAME=Имя

# Абсолютный путь к бинарнику claude CLI.
CLAUDE_PATH=/home/username/.local/bin/claude

# Optional proxy settings.
# Leave empty or remove these lines if proxy is not needed.
# Example:
# http_proxy=http://127.0.0.1:8118
# https_proxy=http://127.0.0.1:8118
# HTTP_PROXY=http://127.0.0.1:8118
# HTTPS_PROXY=http://127.0.0.1:8118
